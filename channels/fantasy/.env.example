# ── Fantasy Channel Environment ──────────────────────────────────
# Fantasy is a Go-native channel — there is no Rust ingestion service.
# Sync runs in-process inside the Go API.

# ── Database & Redis ─────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/myscrollr
REDIS_URL=redis://localhost:6379

# ── Encryption ───────────────────────────────────────────────────
# Base64-encoded 32-byte AES-256 key. Used to encrypt Yahoo OAuth
# refresh tokens at rest in yahoo_users.refresh_token. Must match the
# value used by the core API so desktops and web share the same key.
ENCRYPTION_KEY=your-encryption-key

# ── Go API ───────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
COOLIFY_FQDN=myscrollr.com
CHANNEL_URL=http://localhost:8084

# Optional: override the default Go API port (default: 8084)
# PORT=8084

# ── Yahoo OAuth (Fantasy Sports API) ─────────────────────────────
# Register an app at https://developer.yahoo.com/apps/ with scope
# "Fantasy Sports — Read". The callback URL must match YAHOO_CALLBACK_URL
# exactly (including trailing slash) or token exchange will fail.
YAHOO_CLIENT_ID=your-yahoo-client-id
YAHOO_CLIENT_SECRET=your-yahoo-client-secret
YAHOO_CALLBACK_URL=http://localhost:8084/fantasy/callback

# Optional: override Yahoo endpoints (defaults are the production URLs)
# YAHOO_AUTH_URL=https://api.login.yahoo.com/oauth2/request_auth
# YAHOO_TOKEN_URL=https://api.login.yahoo.com/oauth2/get_token
# YAHOO_API_BASE_URL=https://fantasysports.yahooapis.com/fantasy/v2

# ── Sync loop ────────────────────────────────────────────────────
# Set SYNC_ENABLED=0 to disable the background sync (useful in dev
# when you want to avoid burning Yahoo API quota).
SYNC_ENABLED=1

# Optional: override defaults
# SYNC_INTERVAL_SECS=120
# SYNC_CONCURRENCY=5
