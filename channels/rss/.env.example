# ── RSS Channel Environment ──────────────────────────────────────
# Shared by both the Go API and the Rust ingestion service.

# ── Database & Redis ─────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/myscrollr
REDIS_URL=redis://localhost:6379

# ── Go API ───────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
CHANNEL_URL=http://localhost:8083
INTERNAL_RSS_URL=http://localhost:3004

# Optional: override the default Go API port (default: 8083)
# PORT=8083

# ── Rust Ingestion Service ───────────────────────────────────────
# No external API key required — the service polls public RSS/Atom
# feed URLs directly over HTTPS.

# Optional: override the default service port (default: 3004)
# PORT=3004
