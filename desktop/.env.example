# Desktop app environment variables
# Copy to .env and customize for your environment.

# API base URL (defaults to http://localhost:8080 if not set)
VITE_API_URL=http://localhost:8080

# Local auth base URL and Logto app ID are environment-specific.
# VITE_AUTH_ENDPOINT should be the Logto host only, without /oidc/auth.
# Replace these example placeholders when you have a local or shared auth setup available.
VITE_AUTH_ENDPOINT=your_local_auth_endpoint
VITE_LOGTO_APP_ID=your_local_or_dev_logto_app_id

# Redirect URI remains fixed for the desktop PKCE callback:
# http://127.0.0.1:19284/callback

# Sentry — error monitoring (scrollr-desktop project)
# JS-side DSN for the Tauri webview (ticker + main windows).
VITE_SENTRY_DSN=

# Rust-side DSN baked into the binary at compile time via option_env!().
# Same project as VITE_SENTRY_DSN — separated as env vars so CI can wire
# each one explicitly and so it's grep-able. Must be exported BEFORE
# `cargo build` / `tauri build`. For local `npm run tauri:dev` leave
# empty (Sentry is disabled in debug builds anyway).
SENTRY_DSN_RUST=

# CI-only — used by @sentry/vite-plugin for source map upload.
SENTRY_ORG=
SENTRY_AUTH_TOKEN=
