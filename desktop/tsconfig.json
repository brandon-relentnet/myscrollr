{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "paths": {
      "@/api/client": ["./src/api/client.ts"],
      "@/channels/types": ["../myscrollr.com/src/channels/types.ts"],
      "@/channels/shared": ["../myscrollr.com/src/channels/shared.tsx"],
      "@/*": ["../myscrollr.com/src/*"],
      "~/*": ["../extension/*"],
      "@scrollr/*": ["../channels/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "../channels/*/web/**/*.tsx",
    "../myscrollr.com/src/channels/types.ts",
    "../myscrollr.com/src/channels/shared.tsx"
  ],
  "exclude": ["node_modules", "dist", "src-tauri"]
}
