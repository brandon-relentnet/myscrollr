# ============================================================
# K8s Secrets — DO NOT COMMIT with real values.
# Copy to secrets.yaml, fill in base64-encoded values, apply.
#
#   echo -n "your-value" | base64
#   kubectl apply -f secrets.yaml
# ============================================================
apiVersion: v1
kind: Secret
metadata:
  name: scrollr-secrets
  namespace: scrollr
type: Opaque
data:
  # Shared infrastructure
  DATABASE_URL: ""          # postgresql://user:pass@host:25060/defaultdb?sslmode=require
  REDIS_URL: ""             # rediss://default:pass@host:25061
  ENCRYPTION_KEY: ""        # AES key for OAuth token encryption

  # Logto (auth)
  LOGTO_M2M_APP_ID: ""
  LOGTO_M2M_APP_SECRET: ""
  LOGTO_EXTENSION_APP_ID: ""

  # Stripe (billing)
  STRIPE_SECRET_KEY: ""
  STRIPE_PUBLISHABLE_KEY: ""
  STRIPE_WEBHOOK_SECRET: ""

  # Sequin (CDC)
  SEQUIN_WEBHOOK_SECRET: ""

  # External APIs
  TWELVEDATA_API_KEY: ""
  API_SPORTS_KEY: ""
  YAHOO_CLIENT_ID: ""
  YAHOO_CLIENT_SECRET: ""

  # Support (OS Ticket)
  OSTICKET_API_KEY: ""

  # Transactional email (Resend) — drives password-reset emails + invite scripts
  RESEND_API_KEY: ""
  RESEND_FROM_EMAIL: ""      # e.g. invites@myscrollr.com

  # Sentry — error monitoring (shared across all backend services).
  # Per-service DSNs are inlined directly in each Deployment manifest
  # (k8s/<service>.yaml) because DSNs are write-only ingestion endpoints,
  # not data-exfil credentials. Only the shared keys live here.
  #
  # SENTRY_USER_SALT: generate ONCE with `openssl rand -hex 32`. NEVER
  # rotate — rotating un-clusters every historical event because the
  # hashed user IDs become incompatible.
  SENTRY_USER_SALT: ""
  # Environment tag attached to every event. "production" or "staging".
  ENVIRONMENT: ""
  # Release tag — set by CI to the deployed git SHA. See
  # .github/workflows/deploy.yml for the kubectl set env wiring.
  GIT_SHA: ""
