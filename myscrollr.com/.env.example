# Frontend Environment Variables
# Copy this to .env for local development

# API URL
VITE_API_URL=http://localhost:8080

# Logto authentication
# Production values:
# VITE_LOGTO_ENDPOINT=https://auth.myscrollr.com
# VITE_LOGTO_APP_ID=your_production_logto_app_id
# VITE_LOGTO_RESOURCE=https://api.myscrollr.com
VITE_LOGTO_ENDPOINT=your_local_or_dev_logto_endpoint
VITE_LOGTO_APP_ID=your_local_or_dev_logto_app_id
VITE_LOGTO_RESOURCE=http://localhost:8080

