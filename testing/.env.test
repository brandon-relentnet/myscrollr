# testing/.env.test — environment variables for running services against the
# Docker Compose test stack (testing/docker-compose.test.yml).
#
# Copy this to testing/.env.test and adjust values as needed.
# Usage:
#   docker compose --env-file testing/.env.test -f testing/docker-compose.test.yml up -d
#   source testing/.env.test   # for local service runs

# ---------------------------------------------------------------------------
# Database & Redis — point at test containers (avoid clashing with dev)
# ---------------------------------------------------------------------------

# Core API
DATABASE_URL=postgres://myscrollr_test:myscrollr_test@localhost:5433/myscrollr_test?sslmode=disable
REDIS_URL=redis://localhost:6380/0

# Finance Channel API
FINANCE_DATABASE_URL=postgres://myscrollr_test:myscrollr_test@localhost:5433/myscrollr_test?sslmode=disable
FINANCE_REDIS_URL=redis://localhost:6380/0

# Sports Channel API
SPORTS_DATABASE_URL=postgres://myscrollr_test:myscrollr_test@localhost:5433/myscrollr_test?sslmode=disable
SPORTS_REDIS_URL=redis://localhost:6380/0

# RSS Channel API
RSS_DATABASE_URL=postgres://myscrollr_test:myscrollr_test@localhost:5433/myscrollr_test?sslmode=disable
RSS_REDIS_URL=redis://localhost:6380/0

# Fantasy Channel API
FANTASY_DATABASE_URL=postgres://myscrollr_test:myscrollr_test@localhost:5433/myscrollr_test?sslmode=disable
FANTASY_REDIS_URL=redis://localhost:6380/0

# ---------------------------------------------------------------------------
# Third-party API mocks — redirect all services to Docker mock containers
# ---------------------------------------------------------------------------

# TwelveData — finance Rust service
TWELVEDATA_WS_URL=wss://host.docker.internal:9003/v1/quotes/price
TWELVEDATA_REST_URL=http://host.docker.internal:9002
TWELVEDATA_API_KEY=test_twelvedata_key

# api-sports.io — sports Rust service
API_SPORTS_BASE_URL=http://host.docker.internal:9004
API_SPORTS_KEY=test_api_sports_key

# Yahoo — fantasy Go API
YAHOO_API_BASE_URL=http://host.docker.internal:9005
YAHOO_TOKEN_URL=http://host.docker.internal:9005/oauth2/get_token
YAHOO_AUTH_URL=http://host.docker.internal:9005/oauth2/request_auth
YAHOO_CLIENT_ID=test_yahoo_client_id
YAHOO_CLIENT_SECRET=test_yahoo_client_secret
YAHOO_CALLBACK_URL=http://localhost:8084/yahoo/callback

# Stripe — core Go API
STRIPE_SECRET_KEY=sk_test_mock
STRIPE_PUBLISHABLE_KEY=pk_test_mock
STRIPE_WEBHOOK_SECRET=whsec_test_mock
STRIPE_API_URL=http://host.docker.internal:12111
# Price IDs — use stripe-mock's built-in prices
STRIPE_PRICE_MONTHLY=price_test_monthly
STRIPE_PRICE_ANNUAL=price_test_annual
STRIPE_PRICE_LIFETIME=price_test_lifetime
STRIPE_PRICE_PRO_MONTHLY=price_test_pro_monthly
STRIPE_PRICE_PRO_ANNUAL=price_test_pro_annual
STRIPE_PRICE_ULTIMATE_MONTHLY=price_test_ultimate_monthly
STRIPE_PRICE_ULTIMATE_ANNUAL=price_test_ultimate_annual
STRIPE_LIFETIME_ULTIMATE_COUPON_ID=coupon_test

# Logto — core Go API (already env-var driven)
LOGTO_ENDPOINT=http://host.docker.internal:9001
LOGTO_JWKS_URL=http://host.docker.internal:9001/oidc/jwks
LOGTO_URL=http://host.docker.internal:9001
LOGTO_M2M_RESOURCE=http://localhost
LOGTO_M2M_APP_ID=mock_app_id
LOGTO_M2M_APP_SECRET=mock_app_secret
LOGTO_UPLINK_ROLE_ID=mock_uplink_role
LOGTO_PRO_ROLE_ID=mock_pro_role
LOGTO_ULTIMATE_ROLE_ID=mock_ultimate_role
LOGTO_SUPER_USER_ROLE_ID=mock_super_user_role

# Core API server
API_URL=http://localhost:8080
COOLIFY_FQDN=localhost
